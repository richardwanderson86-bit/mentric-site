---
import PageLayout from '@layouts/PageLayout.astro';
---

<!-- Replace YOUR_FORM_ID with your Formspree form ID -->

<PageLayout title="Contact — Mentric" description="Get in touch with the Mentric team. Book a demo, ask a question, or find out how Mentric can support your coaching practice.">

  <!-- Hero -->
  <section class="relative overflow-hidden bg-glow-gradient">
    <div class="section-container py-10 md:py-14 text-center">
      <p class="category-label mb-4">Get in Touch</p>
      <h1 class="max-w-3xl mx-auto">
        Let's talk about your <span class="text-primary">coaching practice</span>
      </h1>
      <p class="mt-6 max-w-2xl mx-auto text-lg md:text-xl">
        Whether you're an independent coach or managing coaching across an organisation,
        we'd love to show you what Mentric can do.
      </p>
    </div>
  </section>

  <!-- Two-column layout -->
  <section class="py-10 md:py-14">
    <div class="section-container">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-10 lg:gap-14">

        <!-- Left column — Contact Form -->
        <div class="lg:col-span-3">
          <form
            action="https://formspree.io/f/xvzzorrg"
            method="POST"
            class="space-y-6"
          >
            <!-- Name row -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="first-name" class="block text-sm font-medium text-ink mb-2">
                  First name <span class="text-primary">*</span>
                </label>
                <input
                  type="text"
                  id="first-name"
                  name="first-name"
                  required
                  class="w-full rounded-xl border border-border bg-white px-4 py-3 text-sm text-ink placeholder:text-muted/50
                    transition-all duration-200
                    focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary/50"
                  placeholder="Jane"
                />
              </div>
              <div>
                <label for="last-name" class="block text-sm font-medium text-ink mb-2">
                  Last name <span class="text-primary">*</span>
                </label>
                <input
                  type="text"
                  id="last-name"
                  name="last-name"
                  required
                  class="w-full rounded-xl border border-border bg-white px-4 py-3 text-sm text-ink placeholder:text-muted/50
                    transition-all duration-200
                    focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary/50"
                  placeholder="Smith"
                />
              </div>
            </div>

            <!-- Email -->
            <div>
              <label for="email" class="block text-sm font-medium text-ink mb-2">
                Email <span class="text-primary">*</span>
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full rounded-xl border border-border bg-white px-4 py-3 text-sm text-ink placeholder:text-muted/50
                  transition-all duration-200
                  focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary/50"
                placeholder="jane@example.com"
              />
            </div>

            <!-- Organisation -->
            <div>
              <label for="organisation" class="block text-sm font-medium text-ink mb-2">
                Organisation
              </label>
              <input
                type="text"
                id="organisation"
                name="organisation"
                class="w-full rounded-xl border border-border bg-white px-4 py-3 text-sm text-ink placeholder:text-muted/50
                  transition-all duration-200
                  focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary/50"
                placeholder="Your company or practice name"
              />
            </div>

            <!-- Role -->
            <div>
              <label for="role" class="block text-sm font-medium text-ink mb-2">
                Role
              </label>
              <select
                id="role"
                name="role"
                class="w-full rounded-xl border border-border bg-white px-4 py-3 text-sm text-ink
                  transition-all duration-200 appearance-none
                  focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary/50"
              >
                <option value="" disabled selected>Select your role</option>
                <option value="independent-coach">Independent Coach</option>
                <option value="coaching-practice-owner">Coaching Practice Owner</option>
                <option value="hr-ld-manager">HR/L&amp;D Manager</option>
                <option value="other">Other</option>
              </select>
            </div>

            <!-- Message -->
            <div>
              <label for="message" class="block text-sm font-medium text-ink mb-2">
                Message <span class="text-primary">*</span>
              </label>
              <textarea
                id="message"
                name="message"
                required
                rows="5"
                class="w-full rounded-xl border border-border bg-white px-4 py-3 text-sm text-ink placeholder:text-muted/50
                  transition-all duration-200 resize-y
                  focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary/50"
                placeholder="Tell us about your coaching practice and how we can help..."
              ></textarea>
            </div>

            <!-- How did you hear about us? -->
            <div>
              <label for="referral" class="block text-sm font-medium text-ink mb-2">
                How did you hear about us?
              </label>
              <input
                type="text"
                id="referral"
                name="referral"
                class="w-full rounded-xl border border-border bg-white px-4 py-3 text-sm text-ink placeholder:text-muted/50
                  transition-all duration-200
                  focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary/50"
                placeholder="e.g. Google, LinkedIn, a colleague..."
              />
            </div>

            <!-- Submit -->
            <div>
              <button
                type="submit"
                class="btn-primary w-full sm:w-auto px-10 py-3.5 text-base"
              >
                Send Message
              </button>
            </div>

            <!-- GDPR note -->
            <p class="text-xs text-muted leading-relaxed">
              By submitting this form, you agree to our
              <a href="/privacy" class="underline hover:text-primary">Privacy Policy</a>.
              We'll only use your details to respond to your enquiry.
            </p>
          </form>
        </div>

        <!-- Right column — Info cards -->
        <div class="lg:col-span-2 space-y-6">

          <!-- Book a demo card -->
          <div class="card-editorial p-6 md:p-8">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-full bg-primary-light flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
              </div>
              <h3 class="text-lg font-semibold text-ink">Book a demo</h3>
            </div>
            <p class="text-sm text-muted leading-relaxed">
              Prefer to book directly? We'll be adding calendar booking soon.
            </p>
            <div class="mt-4 rounded-lg border border-dashed border-border bg-background/50 px-4 py-6 text-center">
              <p class="text-xs text-muted">Calendar booking coming soon</p>
              <!-- Add Calendly embed here when ready -->
            </div>
          </div>

          <!-- Get in touch card -->
          <div class="card-editorial p-6 md:p-8">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-full bg-primary-light flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <h3 class="text-lg font-semibold text-ink">Get in touch</h3>
            </div>
            <ul class="space-y-3">
              <li class="flex items-center gap-3 text-sm">
                <svg class="w-4 h-4 text-primary shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                <a href="mailto:hello@mentriccoaching.com" class="text-foreground hover:text-primary">
                  hello@mentriccoaching.com
                </a>
              </li>
              <li class="flex items-center gap-3 text-sm">
                <svg class="w-4 h-4 text-primary shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
                </svg>
                <a href="https://www.mentriccoaching.com" class="text-foreground hover:text-primary">
                  www.mentriccoaching.com
                </a>
              </li>
            </ul>
          </div>

          <!-- What to expect card -->
          <div class="card-editorial p-6 md:p-8">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-full bg-primary-light flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <h3 class="text-lg font-semibold text-ink">What to expect</h3>
            </div>
            <ul class="space-y-3">
              <li class="flex items-start gap-3 text-sm text-foreground">
                <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span>We'll get back to you within 24 hours</span>
              </li>
              <li class="flex items-start gap-3 text-sm text-foreground">
                <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span>We'll arrange a personalised demo of the platform</span>
              </li>
              <li class="flex items-start gap-3 text-sm text-foreground">
                <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span>No pressure, no hard sell — just an honest conversation</span>
              </li>
            </ul>
          </div>

        </div>
      </div>
    </div>
  </section>

</PageLayout>
