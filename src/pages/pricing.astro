---
import PageLayout from "@layouts/PageLayout.astro";

const tiers = [
  {
    name: "Essentials",
    tag: "For independent coaches",
    price: "£XX/month + £X per coachee",
    badge: null,
    highlighted: false,
    features: [
      "Up to X coachees",
      "Session scheduling & notes",
      "Goal & journey tracking",
      "Basic assessments",
      "Resource sharing",
      "Messaging",
      "CPD hours tracking",
      "Email support",
    ],
  },
  {
    name: "Professional",
    tag: "For growing practices",
    price: "£XX/month + £X per coachee",
    badge: "Most Popular",
    highlighted: true,
    preamble: "Everything in Essentials, plus:",
    features: [
      "Unlimited coachees",
      "360-degree feedback",
      "AI-powered insights & summaries",
      "Custom assessment templates",
      "Group coaching",
      "Analytics dashboard",
      "Custom branding",
      "Priority support",
    ],
  },
  {
    name: "Enterprise",
    tag: "For organisations",
    price: "Custom",
    badge: null,
    highlighted: false,
    preamble: "Everything in Professional, plus:",
    features: [
      "Multi-programme management",
      "Multi-client white-labelling",
      "Organisation-wide analytics",
      "Competency frameworks",
      "Coach management & caseloads",
      "Bulk coachee import",
      "Audit logging",
      "Dedicated account manager",
      "SSO & advanced security",
      "Custom integrations",
    ],
  },
];

interface ComparisonRow {
  feature: string;
  essentials: boolean | string;
  professional: boolean | string;
  enterprise: boolean | string;
}

interface ComparisonGroup {
  category: string;
  rows: ComparisonRow[];
}

const comparisonData: ComparisonGroup[] = [
  {
    category: "Core",
    rows: [
      { feature: "Session scheduling & notes", essentials: true, professional: true, enterprise: true },
      { feature: "Goal & journey tracking", essentials: true, professional: true, enterprise: true },
      { feature: "Resource sharing", essentials: true, professional: true, enterprise: true },
      { feature: "Messaging", essentials: true, professional: true, enterprise: true },
      { feature: "CPD hours tracking", essentials: true, professional: true, enterprise: true },
      { feature: "Group coaching", essentials: false, professional: true, enterprise: true },
      { feature: "Custom branding", essentials: false, professional: true, enterprise: true },
    ],
  },
  {
    category: "Assessments",
    rows: [
      { feature: "Basic assessments", essentials: true, professional: true, enterprise: true },
      { feature: "Custom assessment templates", essentials: false, professional: true, enterprise: true },
      { feature: "360-degree feedback", essentials: false, professional: true, enterprise: true },
      { feature: "Competency frameworks", essentials: false, professional: false, enterprise: true },
    ],
  },
  {
    category: "Analytics",
    rows: [
      { feature: "Basic reporting", essentials: true, professional: true, enterprise: true },
      { feature: "Analytics dashboard", essentials: false, professional: true, enterprise: true },
      { feature: "AI-powered insights & summaries", essentials: false, professional: true, enterprise: true },
      { feature: "Organisation-wide analytics", essentials: false, professional: false, enterprise: true },
    ],
  },
  {
    category: "Organisation",
    rows: [
      { feature: "Coachee limit", essentials: "Up to X", professional: "Unlimited", enterprise: "Unlimited" },
      { feature: "Multi-programme management", essentials: false, professional: false, enterprise: true },
      { feature: "Multi-client white-labelling", essentials: false, professional: false, enterprise: true },
      { feature: "Coach management & caseloads", essentials: false, professional: false, enterprise: true },
      { feature: "Bulk coachee import", essentials: false, professional: false, enterprise: true },
      { feature: "Audit logging", essentials: false, professional: false, enterprise: true },
      { feature: "SSO & advanced security", essentials: false, professional: false, enterprise: true },
      { feature: "Custom integrations", essentials: false, professional: false, enterprise: true },
    ],
  },
  {
    category: "Support",
    rows: [
      { feature: "Email support", essentials: true, professional: true, enterprise: true },
      { feature: "Priority support", essentials: false, professional: true, enterprise: true },
      { feature: "Dedicated account manager", essentials: false, professional: false, enterprise: true },
    ],
  },
];

const faqs = [
  {
    question: "What counts as a coachee?",
    answer: "A coachee is any active individual on the platform assigned to your coaching practice. Archived or inactive coachees do not count towards your limit.",
  },
  {
    question: "Can I change plans?",
    answer: "Yes, you can upgrade or downgrade your plan at any time. Changes take effect at the start of your next billing cycle.",
  },
  {
    question: "Is there a free trial?",
    answer: "Book a demo and we'll set you up with a trial so you can explore the platform before committing.",
  },
  {
    question: "What payment methods do you accept?",
    answer: "We accept all major credit and debit cards. For Enterprise plans, we also offer invoicing with flexible payment terms.",
  },
  {
    question: "Do you offer discounts for annual billing?",
    answer: "Yes, we offer discounted rates for annual commitments. Contact us for details.",
  },
  {
    question: "What happens to my data if I cancel?",
    answer: "You can export all your data at any time. After cancellation, your data is retained for 30 days and then permanently deleted in accordance with GDPR.",
  },
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((faq) => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer,
    },
  })),
};
---

<PageLayout title="Pricing — Mentric" description="Simple, transparent pricing for the Mentric coaching platform. A monthly platform fee plus a per-coachee rate. No hidden costs." jsonLd={faqJsonLd}>

  <!-- Hero -->
  <section class="relative overflow-hidden bg-glow-gradient">
    <div class="section-container py-10 md:py-14 text-center">
      <p class="category-label mb-4">Pricing</p>
      <h1 class="max-w-3xl mx-auto">
        Simple, transparent <span class="text-primary">pricing</span>
      </h1>
      <p class="mt-6 max-w-2xl mx-auto text-lg md:text-xl">
        A monthly platform fee plus a per-coachee rate. No hidden costs, no surprises.
      </p>
    </div>
  </section>

  <!-- Pricing Tiers -->
  <section class="py-10 md:py-14">
    <div class="section-container">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8 items-start">
        {tiers.map((tier) => (
          <div
            class:list={[
              "relative rounded-xl border p-8 transition-shadow duration-300 flex flex-col",
              tier.highlighted
                ? "border-primary shadow-glow bg-white scale-100 md:scale-105 z-10 ring-2 ring-primary/20"
                : "border-border bg-card shadow-editorial hover:shadow-editorial-lg",
            ]}
          >
            {tier.badge && (
              <div class="absolute -top-3.5 left-1/2 -translate-x-1/2">
                <span class="inline-flex items-center px-4 py-1 rounded-full bg-accent text-ink text-xs font-semibold tracking-wide uppercase shadow-sm">
                  {tier.badge}
                </span>
              </div>
            )}

            <div class="mb-6">
              <p class="text-xs font-semibold uppercase tracking-widest text-muted mb-2">{tier.tag}</p>
              <h3 class="text-2xl md:text-3xl font-bold text-ink">{tier.name}</h3>
            </div>

            <div class="mb-6 pb-6 border-b border-border">
              {tier.name === "Enterprise" ? (
                <p class="text-2xl md:text-3xl font-bold text-primary">Let's talk</p>
              ) : (
                <p class="text-lg font-semibold text-ink">{tier.price}</p>
              )}
            </div>

            {tier.preamble && (
              <p class="text-sm font-medium text-muted mb-3">{tier.preamble}</p>
            )}

            <ul class="space-y-3 mb-8 flex-1">
              {tier.features.map((feature) => (
                <li class="flex items-start gap-3 text-sm text-foreground">
                  <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>{feature}</span>
                </li>
              ))}
            </ul>

            <div class="mt-auto">
              {tier.name === "Enterprise" ? (
                <a href="/contact" class="btn-secondary w-full text-center">Contact Sales</a>
              ) : tier.highlighted ? (
                <a href="/contact" class="btn-primary w-full text-center">Book a Demo</a>
              ) : (
                <a href="/contact" class="btn-secondary w-full text-center">Book a Demo</a>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Feature Comparison Table -->
  <section class="py-10 md:py-14 bg-background">
    <div class="section-container">
      <div class="text-center mb-8">
        <p class="category-label mb-4">Compare Plans</p>
        <h2>Feature comparison</h2>
      </div>

      <div class="overflow-x-auto">
        <table class="w-full min-w-[640px]">
          <thead>
            <tr class="border-b-2 border-border">
              <th class="text-left py-4 pr-4 text-sm font-semibold text-ink w-2/5">Feature</th>
              <th class="text-center py-4 px-4 text-sm font-semibold text-ink w-1/5">Essentials</th>
              <th class="text-center py-4 px-4 text-sm font-semibold text-primary w-1/5">Professional</th>
              <th class="text-center py-4 px-4 text-sm font-semibold text-ink w-1/5">Enterprise</th>
            </tr>
          </thead>
          <tbody>
            {comparisonData.map((group) => (
              <>
                <tr>
                  <td colspan="4" class="pt-8 pb-3">
                    <span class="text-xs font-semibold uppercase tracking-widest text-glow">{group.category}</span>
                  </td>
                </tr>
                {group.rows.map((row) => (
                  <tr class="border-b border-border/60">
                    <td class="py-3.5 pr-4 text-sm text-foreground">{row.feature}</td>
                    <td class="py-3.5 px-4 text-center">
                      {typeof row.essentials === "string" ? (
                        <span class="text-sm text-muted">{row.essentials}</span>
                      ) : row.essentials ? (
                        <svg class="w-5 h-5 text-primary mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                        </svg>
                      ) : (
                        <span class="text-muted/40 text-lg">&mdash;</span>
                      )}
                    </td>
                    <td class="py-3.5 px-4 text-center bg-primary-light/30">
                      {typeof row.professional === "string" ? (
                        <span class="text-sm font-medium text-primary">{row.professional}</span>
                      ) : row.professional ? (
                        <svg class="w-5 h-5 text-primary mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                        </svg>
                      ) : (
                        <span class="text-muted/40 text-lg">&mdash;</span>
                      )}
                    </td>
                    <td class="py-3.5 px-4 text-center">
                      {typeof row.enterprise === "string" ? (
                        <span class="text-sm text-muted">{row.enterprise}</span>
                      ) : row.enterprise ? (
                        <svg class="w-5 h-5 text-primary mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                        </svg>
                      ) : (
                        <span class="text-muted/40 text-lg">&mdash;</span>
                      )}
                    </td>
                  </tr>
                ))}
              </>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-10 md:py-14">
    <div class="section-container max-w-4xl">
      <div class="text-center mb-8">
        <p class="category-label mb-4">FAQs</p>
        <h2>Frequently asked questions</h2>
      </div>

      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="group card-editorial p-0 overflow-hidden">
            <summary class="flex items-center justify-between cursor-pointer px-6 py-5 text-left text-ink font-medium text-base md:text-lg select-none hover:bg-primary-light/30 transition-colors">
              <span>{faq.question}</span>
              <svg
                class="w-5 h-5 text-muted shrink-0 ml-4 transition-transform duration-200 group-open:rotate-180"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-5">
              <p class="text-sm md:text-base text-muted leading-relaxed">{faq.answer}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="py-10 md:py-14">
    <div class="section-container">
      <div class="bg-plum-gradient rounded-2xl px-8 py-14 md:py-20 text-center">
        <h2 class="text-white mb-4">Not sure which plan is right for you?</h2>
        <p class="text-white/80 text-lg md:text-xl max-w-xl mx-auto mb-8">
          Book a demo and we'll help you find the perfect fit.
        </p>
        <a href="/contact" class="btn-accent px-8 py-4 text-base rounded-2xl">Book a Demo</a>
      </div>
    </div>
  </section>

</PageLayout>
